# ─────────────────────────────────────────────────────
# DATABASE (PostgreSQL — use Neon free tier on Vercel)
# ─────────────────────────────────────────────────────
# Get both URLs from https://neon.tech after creating a project.
# On Vercel: add these two in Project → Settings → Environment Variables.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─────────────────────────────────────────────────────
# AUTH (NextAuth v5)
# ─────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="your-secret-here"
# MUST match your Vercel deployment URL exactly (no trailing slash)
NEXTAUTH_URL="https://your-app.vercel.app"

# ─────────────────────────────────────────────────────
# OPTIONAL — Supabase Storage (PDF uploads)
# ─────────────────────────────────────────────────────
SUPABASE_URL="https://xyzcompany.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="pdfs"
